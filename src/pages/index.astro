---
import Layout from '@/layouts/Layout.astro'
import HeroSectionPage from '@/components/blocks/hero-section/hero-section'
import PartnerSection from '@/components/blocks/partner-section/partner-section'
import IndustriesSection from '@/components/blocks/industries-section/industries-section'
import StrategicSection from '@/components/blocks/strategic-section/strategic-section'
// import PopularDishes from '@/components/blocks/popular-dishes/popular-dishes'
// import AboutUs from '@/components/blocks/about-us-section/about-us-page'
// import Testimonials from '@/components/blocks/testimonials-section/testimonials-section'
// import NewItems from '@/components/blocks/new-items-section/new-items'
// import ContactUs from '@/components/blocks/contact-us-section/contact-us-page'
// import Offers from '@/components/blocks/offers-section/offers-section'

import { heroSlides } from '@/assets/data/hero'
// import { popularDishes } from '@/assets/data/popular-dishes'
// import { stats } from '@/assets/data/about-us'
// import { testimonials } from '@/assets/data/testimonials'
// import { newItems } from '@/assets/data/new-items'
// import { contactInfo } from '@/assets/data/contact-us'
// import { GalleryImage } from '@/assets/data/offers'

// Page-specific SEO configuration
const pageTitle = '3D Structures | Steel Detailing Services Australia'
const pageDescription =
  'Fully coordinated structural steel detailing and 3D BIM modelling that bridges structural design with the fabrication floor. Delivered to Australian standards, on your programme.'
const pageKeywords = 'steel detailing Australia, BIM modelling, shop drawings, structural steel, connection design, AS4100'

// Structured data
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '3D Structures',
  description: pageDescription,
  url: 'https://3dstructures.com.au',
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'AU'
  }
}
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} schema={schema}>
  <HeroSectionPage heroSlides={heroSlides} client:load />
  <PartnerSection client:load />
  <IndustriesSection client:load />
  <StrategicSection client:load />

  {/* Sections below — uncomment as each is built */}
  {/* <PopularDishes popularDishes={popularDishes} client:load /> */}
  {/* <AboutUs stats={stats} /> */}
  {/* <Testimonials testimonials={testimonials} client:load /> */}
  {/* <NewItems newItems={newItems} /> */}
  {/* <ContactUs contactInfo={contactInfo} /> */}
  {/* <Offers galleryImage={GalleryImage} /> */}
</Layout>
